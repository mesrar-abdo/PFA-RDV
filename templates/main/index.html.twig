{% extends 'base.html.twig' %}

{% block body %}
<div style="text-align: center; padding: 4rem 2rem;">
    <h1 style="color: var(--primary-calm); font-size: 2.5rem; margin-bottom: 1rem;">
        Welcome to SereneHealth
    </h1>
    
    {% if app.user %}
        <p style="font-size: 1.2rem; color: #555;">
            Hello, <strong>{{ app.user.firstName }}</strong>! 
            You are logged in as a <span style="text-transform: capitalize;">{{ app.user.role }}</span>.
        </p>
        
        <div style="margin-top: 2rem;">
            {% if is_granted('ROLE_DOCTOR') %}
                <a href="#" class="btn-primary">Manage My Schedule</a>
            {% elseif is_granted('ROLE_ADMIN') %}
                <a href="#" class="btn-primary">Admin Dashboard</a>
            {% else %}
                <a href="#" class="btn-primary">Book an Appointment</a>
            {% endif %}
        </div>
    {% else %}
        <p>Please log in to manage your medical appointments.</p>
        <a href="{{ path('app_login') }}" class="btn-primary">Login Now</a>
    {% endif %}
</div>
{% endblock %}