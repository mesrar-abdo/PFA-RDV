{% extends 'base.html.twig' %}

{% block title %}Sign In | SereneHealth{% endblock %}

{% block body %}
<div class="login-container" style="max-width: 400px; margin: 0 auto;">
    <form method="post">
        {% if error %}
            <div style="color: #d62828; margin-bottom: 1rem;">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <h2 style="font-family: 'Montserrat'; color: var(--primary-calm);">Welcome Back</h2>
        <p style="margin-bottom: 2rem; color: #666;">Please enter your details to access your appointments.</p>

        <label for="inputEmail">Email Address</label>
        <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus style="width: 100%; padding: 10px; margin: 10px 0; border-radius: 8px; border: 1px solid var(--accent-soft);">

        <label for="inputPassword">Password</label>
        <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required style="width: 100%; padding: 10px; margin: 10px 0; border-radius: 8px; border: 1px solid var(--accent-soft);">

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="checkbox mb-3" style="margin: 15px 0;">
            <label>
                <input type="checkbox" name="_remember_me"> Remember me
            </label>
        </div>

        <button class="btn-primary" type="submit" style="width: 100%; margin-top: 1rem;">
            Sign in
        </button>
        <div style="text-align: center; margin-top: 1.5rem;">
        <a href="{{ path('app_register') }}" style="color: var(--primary-calm); text-decoration: none; font-size: 0.9rem;">Don't have an account? Register</a>
    </div>
    </form>
</div>
{% endblock %}