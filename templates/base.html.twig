<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SereneHealth | Appointments{% endblock %}</title>
    
    {# Google Fonts: Inter for readability & Montserrat for a clean medical feel #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Montserrat:wght@300;500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-ethereal: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%);
            --accent-soft: #a8dadc;
            --primary-calm: #457b9d;
            --text-main: #2b2d42;
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(255, 255, 255, 0.3);
            --shadow-soft: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            background: var(--bg-ethereal);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Glassmorphism Header */
        header {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--glass-border);
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 1000;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: var(--shadow-soft);
        }

        .logo {
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            font-size: 1.5rem;
            color: var(--primary-calm);
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        nav a {
            text-decoration: none;
            color: var(--text-main);
            margin-left: 2rem;
            font-weight: 500;
            transition: color 0.3s ease;
        }

        nav a:hover {
            color: var(--primary-calm);
        }

        /* Main Content Container */
        main {
            flex: 1;
            padding: 3rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
            box-sizing: border-box;
        }

        .content-card {
            background: var(--glass-bg);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border-radius: 20px;
            border: 1px solid var(--glass-border);
            padding: 2.5rem;
            box-shadow: var(--shadow-soft);
            animation: fadeIn 0.8s ease-out;
        }

        /* Footer */
        footer {
            padding: 2rem;
            text-align: center;
            font-size: 0.9rem;
            color: #8d99ae;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Buttons & Utility */
        .btn-primary {
            background: var(--primary-calm);
            color: white;
            border: none;
            padding: 0.8rem 1.5rem;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(69, 123, 157, 0.3);
        }

        {% block stylesheets %}{% endblock %}
    </style>
</head>
<body>
    <header>
        <a href="/" class="logo">Serene<span>Health</span></a>
        <nav>
            <a href="#">Find a Doctor</a>
            <a href="#">My Records</a>
            <a href="#">Support</a>
            <a href="#" class="btn-primary">Book Appointment</a>
        </nav>
    </header>

    <main>
        <div class="content-card">
            {% block body %}{% endblock %}
        </div>
    </main>

    <footer>
        &copy; {{ "now"|date("Y") }} SereneHealth Medical Group. All rights reserved.
    </footer>

    {% block javascripts %}{% endblock %}
</body>
</html>